#!/usr/bin/env bash
# Odoo registry-load validation gate (pre-push tier) — shipped by the AI_AUTO odoo domain
# pack. In GLOBAL mode this hook is NOT auto-wired: `ai-domain-pack refresh --apply`
# materializes the pack as a REFERENCE under .omx/domain-packs/odoo/ (gitignored), and
# `ai-auto setup` installs only the framework pre-commit/post-commit shims. To activate this
# gate, wire it yourself once: copy or symlink this file to .git/hooks/pre-push (or point
# core.hooksPath at the pack's hooks dir). Until wired, it is a dormant reference and never fires.
# Blocks push when changed custom-addons modules fail to install/update on the
# parity-pinned warm base (catches view-inheritance/field/registry errors that odoo.sh
# would otherwise fail on). ~95s via warm base.
#
# Setup (once per environment): point ODOO_HARNESS_DIR at your local validation harness
#   export ODOO_HARNESS_DIR="/path/to/00. DATA/harness"
# Until it is set, this hook blocks changed custom-addons pushes as
# NOT VALIDATED (validator unavailable). A human-acked unvalidated push must carry
# launcher-backed principal evidence; an env-only bypass is refused.
#
# Override (emergency):   SKIP_ODOO_VALIDATE=1 AI_AUTO_ODOO_UNVALIDATED_ACK_BY=<principal> git push
# Fail-closed: once the harness is configured, a missing warm base is auto-built (first
# push, ~10min) instead of skipped, so validation is never silently bypassed.
# ODOO_SKIP_AUTO_BASE=1 blocks-with-instructions instead of auto-building.
set -u

PROJECT="$(git rev-parse --show-toplevel)"
HARNESS="${ODOO_HARNESS_DIR:-}"

odoo_ack_key_file() {
  if [ -n "${AI_AUTO_PROVENANCE_KEY_FILE:-}" ]; then printf '%s\n' "${AI_AUTO_PROVENANCE_KEY_FILE}"
  elif [ -n "${AI_AUTO_HOME:-}" ]; then printf '%s/.provenance-key\n' "${AI_AUTO_HOME}"
  else printf '%s/.config/ai-auto/provenance.key\n' "${HOME:-/root}"; fi
}

odoo_ack_abs_path() {
  local path="$1"
  if command -v realpath >/dev/null 2>&1; then
    realpath -m -- "${path}" 2>/dev/null && return 0
  fi
  AI_AUTO_ABS_PATH="${path}" python3 - <<'PY' 2>/dev/null
import os
print(os.path.realpath(os.environ["AI_AUTO_ABS_PATH"]))
PY
}

# Resolution failure (realpath -m and the python3 fallback both fail) also REFUSES (fail closed):
# treating an unresolvable key path as "not in tree" would let a plant escape the trust boundary.
odoo_ack_key_in_tree() {
  local keyfile top rp
  keyfile="$(odoo_ack_key_file)"
  top="$(odoo_ack_abs_path "${PROJECT}")" || return 0
  rp="$(odoo_ack_abs_path "${keyfile}")" || return 0
  case "${rp}/" in "${top}/"*) return 0 ;; esac
  return 1
}

odoo_ack_hmac() {
  local keyfile mode
  keyfile="$(odoo_ack_key_file)"
  odoo_ack_key_in_tree && return 0
  [ -s "${keyfile}" ] || return 0
  [ -O "${keyfile}" ] || return 0
  mode="$(stat -c '%a' "${keyfile}" 2>/dev/null || echo 777)"
  [ $(( 0${mode} & 077 )) -eq 0 ] || return 0
  AI_AUTO_PEV_KEYFILE="${keyfile}" python3 -c 'import hmac,hashlib,os,sys; k=open(os.environ["AI_AUTO_PEV_KEYFILE"],"rb").read(); sys.stdout.write(hmac.new(k,sys.stdin.buffer.read(),hashlib.sha256).hexdigest())' 2>/dev/null
}

odoo_ack_principal_normalized() {
  case "${1:-}" in
    codex|claude) printf '%s\n' "$1" ;;
    gemini|agy) printf '%s\n' gemini ;;
    *) return 1 ;;
  esac
}

odoo_ack_evidence_ok() {
  local ack ev stored expected
  ack="$(odoo_ack_principal_normalized "${AI_AUTO_ODOO_UNVALIDATED_ACK_BY:-}")" || return 1
  ev="${AI_AUTO_PRINCIPAL_EVIDENCE:-${PROJECT}/.omx/state/principal-runtime/current.env}"
  [ -f "${ev}" ] && [ ! -L "${ev}" ] || return 1
  grep -Fqx "principal_runtime=${ack}" "${ev}" || return 1
  grep -Fqx "execution_mode=principal" "${ev}" || return 1
  grep -Fqx "source=ai-auto-principal-launcher" "${ev}" || return 1
  grep -Fqx "workspace=${PROJECT}" "${ev}" || return 1
  stored="$(sed -n 's/^evidence_hmac=//p' "${ev}" | head -n 1)"
  [ -n "${stored}" ] || return 1
  expected="$(printf 'marker_type=principal_evidence\nprincipal_runtime=%s\nexecution_mode=principal\nsource=ai-auto-principal-launcher\nworkspace=%s\n' "${ack}" "${PROJECT}" | odoo_ack_hmac)"
  [ -n "${expected}" ] && [ "${expected}" = "${stored}" ]
}

odoo_unvalidated_block() {
  local reason
  reason="${1:-validator unavailable}"
  echo "[pre-push] ❌ BLOCKED: Odoo validation NOT VALIDATED (validator unavailable): ${reason}"
  echo "[pre-push]     Configure ODOO_HARNESS_DIR/docker/validate-warm.sh, or use launcher-backed ack:"
  echo "[pre-push]     SKIP_ODOO_VALIDATE=1 AI_AUTO_ODOO_UNVALIDATED_ACK_BY=<principal> git push"
  exit 1
}

odoo_unvalidated_ack_or_block() {
  local reason
  reason="${1:-validator unavailable}"
  if [ "${SKIP_ODOO_VALIDATE:-0}" = "1" ] && odoo_ack_evidence_ok; then
    echo "[pre-push] ⚠️  Odoo validation NOT VALIDATED (validator unavailable): ${reason}"
    echo "[pre-push]     unvalidated push, human-acked by ${AI_AUTO_ODOO_UNVALIDATED_ACK_BY}"
    exit 0
  fi
  odoo_unvalidated_block "${reason}"
}

# Read the push refs from stdin ONCE (git feeds "<lref> <lsha> <rref> <rsha>" lines)
# and derive the changed custom-addons modules across the COMMITS being pushed. Both the
# docker-free manifest screen (below) and the warm-base validation (later) consume this
# one module list, so neither has to guess an integration base and stdin is read exactly
# once. Commit-list based (not a worktree diff): a clean checkout's first push resolves.
push_refs="$(cat)"
zero=0000000000000000000000000000000000000000
mods=""
# Runtime-relevant files OUTSIDE custom-addons/ that can break the odoo.sh build/runtime
# even though they touch zero modules (RED2-3): a bumped/broken python dep or a changed
# build image/compose file. Tracked separately from $mods so an empty module scope caused
# by ONLY this class of change is never mistaken for "nothing relevant changed" below.
runtime_files=""
# RED7-3: this MUST match the runtime filename anywhere in the path (any subdirectory),
# not only at the repo root -- a root-anchored `^...$` pattern lets a Dockerfile/
# requirements.txt/compose file nested under docker/, deploy/, .docker/, etc. evade the
# scan entirely, silently falling back to the pre-RED2-3 exit-0-skip. The leading
# `(.*/)?` makes the directory prefix optional so both `requirements.txt` (root) and
# `docker/requirements.txt` (subdir) match, while the filename part still forbids an
# embedded slash so it only ever matches the basename, not an arbitrary substring.
# RED11-3: the match against this regex below MUST use `grep -Ei` (case-insensitive) --
# `dockerfile`, `DOCKERFILE`, `docker-compose.YML` are all real, buildable filenames that
# evaded the case-sensitive match. The `(docker-)?compose` alternative (in place of the
# old `docker-compose`-only form) also covers Compose Specification v2's own default
# discovery names `compose.yaml`/`compose.yml` (no "docker-" prefix at all), not only the
# legacy `docker-compose.yml` form. Still basename-anchored via `(.*/)?...$`, so an
# unrelated file merely containing "compose" (e.g. `recompose.yaml`) does not match.
runtime_re='^(.*/)?(requirements[^/]*\.txt|Dockerfile[^/]*|(docker-)?compose[^/]*\.ya?ml|Pipfile(\.lock)?|pyproject\.toml|setup\.(py|cfg))$'
while read -r _lref lsha _rref rsha; do
  # skip branch deletions (local sha all-zeros) and empty lines
  case "${lsha:-}" in ""|"$zero") continue ;; esac
  case "${rsha:-}" in
    ""|"$zero") commits="$(git -C "$PROJECT" rev-list "$lsha" --not --remotes 2>/dev/null)" ;;  # new branch
    *)          commits="$(git -C "$PROJECT" rev-list "$rsha..$lsha" 2>/dev/null)" ;;
  esac
  # RED11-2: `diff-tree` WITHOUT `-m`/`-c`/`--cc` prints NOTHING for a merge commit, by
  # git's own design (a merge is only diffed against a parent when explicitly asked) --
  # so an "evil merge" that injects a Dockerfile/requirements.txt/custom-addons change
  # ONLY during conflict resolution (content present in neither parent's own tree) was
  # completely invisible to both $mods and $runtime_files, even though `rev-list` walks
  # every commit in the pushed range including merges. `-m` shows a diff of the commit
  # against EACH of its parents, one after another; a genuinely merge-only file (differs
  # from every parent) then appears in at least one of those per-parent diffs and is
  # caught (duplicates across parents are harmless -- deduped by `sort -u` below). For an
  # ordinary single-parent (non-merge) commit, `-m` diffs against that one parent, i.e.
  # identical output to the pre-fix invocation -- no over- or under-detection is
  # introduced for the common case. `-m` is applied to one already-resolved commit sha at
  # a time here (never to a whole `rev-range` argument), so it stays scoped to exactly the
  # pushed commits, not verbose across history.
  changed_files="$(printf '%s\n' "$commits" | while read -r c; do
        [ -n "$c" ] && git -C "$PROJECT" diff-tree -r -m --no-commit-id --name-only "$c" 2>/dev/null
      done)"
  m="$(printf '%s\n' "$changed_files" | sed -n 's#^custom-addons/\([^/]*\)/.*#\1#p')"
  r="$(printf '%s\n' "$changed_files" | grep -Ei "$runtime_re")"
  mods="$mods$m
"
  runtime_files="$runtime_files$r
"
done <<EOF
${push_refs}
EOF
mods=$(printf '%s' "$mods" | sed '/^$/d' | sort -u | tr '\n' ' ')
runtime_files=$(printf '%s' "$runtime_files" | sed '/^$/d' | sort -u | tr '\n' ' ')

# Static manifest-integrity screen (no docker, no harness): a __manifest__.py listing a
# data/demo file that does not exist fails `odoo -u <module>` and odoo.sh at load.
# Deterministic (a listed path exists or not) -> fail-closed. It needs neither docker nor
# the warm base and is found co-installed next to this hook (.githooks/) or in the
# configured harness, so it runs FIRST -- before the harness/docker skips below -- on
# exactly the pushed modules (no integration-base guess). This is the one validation that
# still fires when ODOO_HARNESS_DIR is unset. SKIP_ODOO_VALIDATE=1 bypasses it (above).
if [ -n "$mods" ]; then
  mf_screen=""
  for mf_cand in "$(dirname "$0")/check-manifest-files.py" "${HARNESS:+$HARNESS/check-manifest-files.py}"; do
    if [ -n "$mf_cand" ] && [ -f "$mf_cand" ]; then mf_screen="$mf_cand"; break; fi
  done
  if [ -n "$mf_screen" ]; then
    # shellcheck disable=SC2086  # $mods is an intentional space-separated module list
    if ! ( cd "$PROJECT" && python3 "$mf_screen" --modules $mods ); then
      echo "[pre-push] ❌ BLOCKED: a __manifest__.py references a missing file (see above)."
      echo "[pre-push]     Fix the path/file, or bypass with: SKIP_ODOO_VALIDATE=1 git push"
      exit 1
    fi
  fi
fi

if [ -z "$mods" ]; then
  if [ -n "$runtime_files" ]; then
    # RED2-3: empty module scope does NOT mean "nothing relevant changed" here — a
    # runtime-relevant file outside custom-addons/ changed (deps/build image/compose).
    # Never exit clean-green silently; require the same NOT-VALIDATED ack/block path as
    # every other "could not actually validate" reason below.
    echo "[pre-push] ⚠️  runtime-relevant file(s) changed outside custom-addons/ (no module scope to widen validation to): $runtime_files"
    odoo_unvalidated_ack_or_block "runtime-relevant change outside custom-addons/ scope (no module to validate against): $runtime_files"
  fi
  echo "[pre-push] no custom-addons changes; skip Odoo validation"
  exit 0
fi

# An explicit environment-only bypass is never enough for changed Odoo modules.
if [ "${SKIP_ODOO_VALIDATE:-0}" = "1" ]; then
  odoo_unvalidated_ack_or_block "explicit validation skip requested"
fi

# The harness location is environment-specific (it sits next to your local Odoo source).
# Require it explicitly; fail closed until configured unless launcher evidence acks the
# unvalidated push.
if [ -z "$HARNESS" ]; then
  odoo_unvalidated_ack_or_block "ODOO_HARNESS_DIR not set"
fi

if [ -n "$mods" ] && [ -x "$HARNESS/changed-module-scope.py" ]; then
  mods="$(python3 "$HARNESS/changed-module-scope.py" --addons-root "$PROJECT/custom-addons" --changed $mods --reverse-deps --format space)"
fi

# Static action-shape screen (no docker needed): flag CHANGED act_window popups
# missing `views` — the Odoo 19 raw-doAction(dict) crash class. Advisory only: it
# lists popups to CONFIRM on local serve (popup-smoke.mjs, console-error=0); it
# never blocks the push. The confirm step is the runtime oracle, not this screen.
if [ -x "$HARNESS/check-action-shape.py" ]; then
  ( cd "$PROJECT" && python3 "$HARNESS/check-action-shape.py" ) || true
fi

# Static inherited-field overlap screen (no docker): flag a (inherited model,
# field name) pair written by 2+ CHANGED addons — the cross-addon BEHAVIORAL
# collision class warm registry-load stays green on (queue odoo:post-install-gap-
# field-semantic-collision). Advisory only: it nominates pairs to CONFIRM via
# validate-full.sh (post-install test tier); it never blocks the push.
if [ -x "$HARNESS/check-inherited-field-overlap.py" ]; then
  ( cd "$PROJECT" && python3 "$HARNESS/check-inherited-field-overlap.py" ) || true
fi

if [ -n "$mods" ]; then
  if [ -x "$HARNESS/check-schema-catalog.py" ]; then
    schema_catalog="$HARNESS/.odoo-schema-catalog.json"
    if [ -x "$HARNESS/harness-slug.sh" ]; then
      # shellcheck source=/dev/null
      . "$HARNESS/harness-slug.sh"
      schema_catalog="$HARNESS/.warm-base.$(harness_proj_slug "$PROJECT").${ODOO_BASE_DB:-base}.schema-catalog.json"
    fi
    # shellcheck disable=SC2086  # $mods is an intentional space-separated module list.
    if ! ( cd "$PROJECT" && ODOO_SCHEMA_CATALOG="$schema_catalog" python3 "$HARNESS/check-schema-catalog.py" --modules $mods --strict ); then
      echo "[pre-push] ❌ BLOCKED: schema catalog screen found invalid model/field references (see above)."
      echo "[pre-push]     Rebuild the warm base/catalog, fix the reference, or bypass with: SKIP_ODOO_VALIDATE=1 git push"
      exit 1
    fi
  else
    # RED2-4: this lane is BLOCKING when it runs; a missing/non-executable script must
    # never silently drop that coverage. Mirror verify-machinery.sh's LOUD NOT-VALIDATED
    # scanner-absence marker instead of a bare no-op `if`.
    echo "[pre-push] NOT-VALIDATED (scanner check-schema-catalog.py unavailable): schema/model-field reference screen did NOT run for changed modules ($mods) — 'push validated' does NOT imply 'schema-catalog-checked'. Restore check-schema-catalog.py at \$HARNESS to close this gap."
  fi
fi

if [ -n "$mods" ] && [ -x "$HARNESS/check-parity.sh" ]; then
  if ! "$HARNESS/check-parity.sh" "$PROJECT"; then
    echo "[pre-push] ❌ BLOCKED: warm base parity is unconfirmed/stale. Rebuild with ODOO_SH_POINT_RELEASE=<point-release> \"$HARNESS/prepare-base-db.sh\" \"$PROJECT\""
    exit 1
  fi
fi

if ! docker info >/dev/null 2>&1; then
  odoo_unvalidated_ack_or_block "docker unavailable"
fi
if [ ! -x "$HARNESS/validate-warm.sh" ]; then
  odoo_unvalidated_ack_or_block "validate-warm.sh not executable at: $HARNESS"
fi

echo "[pre-push] Odoo validating changed modules: $mods"

"$HARNESS/validate-warm.sh" "$PROJECT" $mods
rc=$?
if [ "$rc" = "3" ]; then
  # Warm base missing. Fail-closed: never silently skip. Auto-build it once (default), or
  # block-with-instructions if ODOO_SKIP_AUTO_BASE=1.
  if [ "${ODOO_SKIP_AUTO_BASE:-0}" = "1" ]; then
    echo "[pre-push] ❌ BLOCKED: warm base not built. Build it: \"$HARNESS/prepare-base-db.sh\" \"$PROJECT\"  (or SKIP_ODOO_VALIDATE=1 git push to bypass)"
    exit 1
  fi
  echo "[pre-push] ⏳ first-time setup: warm base missing — building it now (~10min, one-time for this project)..."
  if ! "$HARNESS/prepare-base-db.sh" "$PROJECT"; then
    echo "[pre-push] ❌ BLOCKED: base build failed (a custom module is not installable on a clean base). Fix the error above, or SKIP_ODOO_VALIDATE=1 git push to bypass."
    exit 1
  fi
  echo "[pre-push] base built — re-running validation..."
  "$HARNESS/validate-warm.sh" "$PROJECT" $mods
  rc=$?
fi
if [ "$rc" != "0" ]; then
  echo "[pre-push] ❌ BLOCKED: Odoo validation failed. Fix the error above, or override: SKIP_ODOO_VALIDATE=1 git push"
  exit 1
fi
echo "[pre-push] ✅ Odoo validation passed"; exit 0
