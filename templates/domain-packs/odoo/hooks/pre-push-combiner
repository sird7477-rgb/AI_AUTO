#!/usr/bin/env bash
# AI_AUTO pre-push COMBINER (odoo domain pack) — runs BOTH gates on one push:
#   (1) the framework binding gate (the baked engine hooks/pre-push, review-gate binding), and
#   (2) the odoo domain-pack validation gate (registry-load / validate-warm of the pushed tree).
#
# WHY a combiner: git feeds the push refs on stdin ONCE, and the plain framework shim only
# execs the engine hook, so the odoo gate never fires. This captures stdin and replays it to
# each gate; a non-zero from either blocks the push.
#
# INSTALL (once per repo; hooks are NOT transferred by clone/worktree-add):
#   cp this file to "$(git rev-parse --git-common-dir)/hooks/pre-push" (shared by all worktrees)
#   and make it executable. Back up any existing shim first. NOTE: re-running `ai-auto setup`
#   restores the plain framework shim and DROPS the odoo chain — re-install this combiner then.
#
# CONFIG (env; both have sensible resolution so no shell-profile edit is required):
#   AI_AUTO_HOME       engine root that holds hooks/pre-push + hooks/git-scrub.sh.
#                      Default: resolved from this file's location if it sits under an engine
#                      checkout, else must be exported. (A baked install may hardcode it.)
#   ODOO_HARNESS_DIR   local validation harness ("00. DATA/harness"). If unset, the odoo gate
#                      fail-closes NOT-VALIDATED on custom-addons changes (ack-bypass exists).
set -uo pipefail

# --- resolve AI_AUTO_HOME -----------------------------------------------------------------
# Prefer an explicit env; else try to locate an engine checkout that has hooks/pre-push.
if [ -z "${AI_AUTO_HOME:-}" ]; then
  for _cand in "$HOME/workspace/ai-lab" "/root/workspace/ai-lab" "/opt/ai-lab"; do
    if [ -x "$_cand/hooks/pre-push" ]; then AI_AUTO_HOME="$_cand"; break; fi
  done
fi
AI_AUTO_HOME="${AI_AUTO_HOME:-}"

refs="$(cat)"   # capture the push refs from stdin ONCE, replay to each gate

# --- gate 1: framework binding (baked engine hook), with the shim's BLAST hardening --------
if [ -n "$AI_AUTO_HOME" ]; then
  if [ -f "$AI_AUTO_HOME/hooks/git-scrub.sh" ] && bash -n "$AI_AUTO_HOME/hooks/git-scrub.sh" 2>/dev/null; then
    . "$AI_AUTO_HOME/hooks/git-scrub.sh"
  fi
  if ! [ -f "$AI_AUTO_HOME/hooks/pre-push" ] || ! [ -x "$AI_AUTO_HOME/hooks/pre-push" ]; then
    printf '[pre-push] WARNING: engine hook missing/not runnable (%s); re-run '\''ai-auto setup'\''. Skipping binding gate (NOT blocking).\n' "$AI_AUTO_HOME/hooks/pre-push" >&2
  elif ! bash -n "$AI_AUTO_HOME/hooks/pre-push" 2>/dev/null; then
    printf '[pre-push] WARNING: engine hook does not parse (%s); re-run '\''ai-auto setup'\''. Skipping binding gate (NOT blocking).\n' "$AI_AUTO_HOME/hooks/pre-push" >&2
  else
    printf '%s\n' "$refs" | PATH="$AI_AUTO_HOME/scripts:$AI_AUTO_HOME/tools:$PATH" "$AI_AUTO_HOME/hooks/pre-push" "$@"
    brc=$?
    [ "$brc" -ne 0 ] && exit "$brc"
  fi
else
  printf '[pre-push] WARNING: AI_AUTO_HOME unresolved; skipping framework binding gate (NOT blocking). Export AI_AUTO_HOME to enable it.\n' >&2
fi

# --- gate 2: odoo domain-pack validation (per-worktree materialized reference) -------------
top="$(git rev-parse --show-toplevel 2>/dev/null || true)"
ODOO_HOOK="${top:+$top/.omx/domain-packs/odoo/hooks/pre-push}"
if [ -n "$ODOO_HOOK" ] && [ -f "$ODOO_HOOK" ]; then
  if [ -x "$ODOO_HOOK" ]; then
    printf '%s\n' "$refs" | "$ODOO_HOOK" "$@"
    orc=$?
  else
    # Present but not executable (e.g. an install that lost the exec bit) must
    # still run the oracle -- an absent-vs-non-executable distinction that was
    # previously conflated into one silent skip. Only genuine absence is quiet.
    printf '[pre-push] WARNING: odoo pack hook present but not executable (%s); running via bash and continuing -- fix the exec bit\n' "$ODOO_HOOK" >&2
    printf '%s\n' "$refs" | bash "$ODOO_HOOK" "$@"
    orc=$?
  fi
  [ "$orc" -ne 0 ] && exit "$orc"
fi

exit 0
