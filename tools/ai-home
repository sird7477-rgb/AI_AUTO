#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  LINK_TARGET="$(readlink "$SOURCE")"
  case "$LINK_TARGET" in
    /*)
      SOURCE="$LINK_TARGET"
      ;;
    *)
      SOURCE="${SOURCE_DIR}/${LINK_TARGET}"
      ;;
  esac
done

TOOL_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
AI_LAB_ROOT="$(cd "${TOOL_DIR}/.." && pwd)"

# Source the canonical git-exec-env scrub (hooks/git-scrub.sh) so `--status`'s worktree-scanning
# `git status` below cannot execute a hostile `.git/config core.fsmonitor=<program>` (RCE). This
# standalone entrypoint is NOT run under the ai-auto launcher, so it lacks the process-wide
# core.fsmonitor='' env pin otherwise; the pin (env-config, higher precedence than repo-local
# config) closes the fsmonitor HOOK-PROGRAM vector that --attr-source cannot reach. Presence-guarded
# so `set -e` cannot abort on an absent/partial copy.
# shellcheck source=../hooks/git-scrub.sh
if [ -f "${AI_LAB_ROOT}/hooks/git-scrub.sh" ] && bash -n "${AI_LAB_ROOT}/hooks/git-scrub.sh" 2>/dev/null; then . "${AI_LAB_ROOT}/hooks/git-scrub.sh"; fi

case "${1:-}" in
  -h|--help)
    cat <<'USAGE'
Usage: ai-home [--path|--cd|--status]
       AI_AUTO [--path|--cd|--status]

Show the local AI_AUTO / ai-lab checkout path and common commands.

Options:
  --path     print only the checkout path
  --cd       print a shell command that moves to the checkout
  --status   run git status --short in the checkout

Examples:
  AI_AUTO
  cd "$(AI_AUTO --path)"
  AI_AUTO --status
  cd "$(ai-home --path)"
  eval "$(ai-home --cd)"
  ai-home --status
USAGE
    exit 0
    ;;
  --path)
    printf '%s\n' "$AI_LAB_ROOT"
    exit 0
    ;;
  --cd)
    printf 'cd %q\n' "$AI_LAB_ROOT"
    exit 0
    ;;
  --status)
    # --attr-source=<empty-tree> disarms an in-repo .gitattributes+`.git/config` clean-filter
    # driver that `git status` would otherwise run on a stat-dirty tracked blob (RCE).
    _et="$(git -C "$AI_LAB_ROOT" hash-object -t tree /dev/null 2>/dev/null || echo 4b825dc642cb6eb9a060e54bf8d69288fbee4904)"
    git -C "$AI_LAB_ROOT" --attr-source="$_et" status --short
    exit 0
    ;;
  "")
    ;;
  *)
    echo "Unknown option: $1"
    echo "Run ai-home --help for usage."
    exit 2
    ;;
esac

cat <<INFO
AI_AUTO checkout:
  ${AI_LAB_ROOT}

Move there:
  $(printf 'cd %q' "$AI_LAB_ROOT")

Useful commands:
  AI_AUTO --status
  ai-refactor-scan /path/to/project
  ai-rebuild-plan /path/to/project
  ai-split-plan --source path/to/monolith.py --domain-pack trading --output .omx/rebuild/split-plan.json
  ai-split-dry-run --plan .omx/rebuild/split-plan.json
  ai-split-apply --plan .omx/rebuild/split-plan.json --execute-approved-plan
  ai-plan-status .omx/plans/plan.json
  ai-interview-record --plan .omx/plans/plan.json --field user_decisions --answer "..."
  ai-plan-review .omx/plans/plan.json
  ai-plan-export .omx/plans/plan.json --output .omx/plans/plan-export.md
  feedback-collect
  workspace-scan
  ai-register /path/to/existing-repo
  cd "\$(AI_AUTO --path)" && ./scripts/bootstrap-ai-lab.sh
  cd "\$(AI_AUTO --path)" && ./scripts/install-global-files.sh
INFO
