#!/usr/bin/env python3
"""Status and refresh helper for AI_AUTO optional domain packs."""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
from datetime import datetime, timezone
from pathlib import Path


SCHEMA = 1
MANIFEST_DIR = ".omx/domain-packs/.manifest"
SAFE_STATE_OK = {"current", "new_source_pack", "adoptable"}
REFRESHABLE_STATES = SAFE_STATE_OK | {"outdated_clean", "deliberately_removed"}
PACK_NAME_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]*$")


def resolve_ai_lab_root() -> Path:
    source = Path(__file__).resolve()
    return source.parent.parent


def git_root_or_path(path: Path) -> Path:
    try:
        result = subprocess.run(
            ["git", "-C", str(path), "rev-parse", "--show-toplevel"],
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        return Path(result.stdout.strip()).resolve()
    except (OSError, subprocess.CalledProcessError):
        return path.resolve()


def source_branch(ai_lab_root: Path) -> str:
    override = os.environ.get("AI_AUTO_TEMPLATE_SOURCE_BRANCH_OVERRIDE")
    if override:
        return override
    try:
        result = subprocess.run(
            ["git", "-C", str(ai_lab_root), "rev-parse", "--abbrev-ref", "HEAD"],
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        return result.stdout.strip() or "unknown"
    except (OSError, subprocess.CalledProcessError):
        return "unknown"


def stable_channel(ai_lab_root: Path) -> tuple[str, str, str]:
    branch = source_branch(ai_lab_root)
    if branch == "main":
        return branch, "stable", "yes"
    return branch, "experimental", "no"


def sha256_file(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


def file_map(root: Path) -> dict[str, str]:
    files: dict[str, str] = {}
    if not root.exists():
        return files
    for path in sorted(root.rglob("*")):
        if path.is_symlink():
            raise RuntimeError(f"refusing symlink in domain pack: {path}")
        if not path.is_file():
            continue
        rel = path.relative_to(root).as_posix()
        files[rel] = sha256_file(path)
    return files


def root_hash(files: dict[str, str]) -> str:
    digest = hashlib.sha256()
    for rel, file_hash in sorted(files.items()):
        digest.update(rel.encode("utf-8"))
        digest.update(b"\0")
        digest.update(file_hash.encode("ascii"))
        digest.update(b"\n")
    return digest.hexdigest()


def manifest_path(target: Path, pack: str) -> Path:
    return target / MANIFEST_DIR / f"{pack}.json"


def read_manifest(target: Path, pack: str) -> tuple[dict | None, str | None]:
    path = manifest_path(target, pack)
    if not path.exists():
        return None, None
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        return None, f"unreadable_manifest:{exc}"
    if data.get("schema") != SCHEMA or data.get("pack") != pack:
        return None, "invalid_manifest"
    files = data.get("files")
    if not isinstance(files, dict) or not all(isinstance(k, str) and isinstance(v, str) for k, v in files.items()):
        return None, "invalid_manifest_files"
    return data, None


def write_manifest(target: Path, pack: str, source_files: dict[str, str], ai_lab_root: Path) -> None:
    version_path = ai_lab_root / "templates/automation-base/AI_AUTO_TEMPLATE_VERSION"
    template_version = version_path.read_text(encoding="utf-8").strip() if version_path.exists() else "unknown"
    path = manifest_path(target, pack)
    path.parent.mkdir(parents=True, exist_ok=True)
    data = {
        "schema": SCHEMA,
        "pack": pack,
        "source": f"templates/domain-packs/{pack}",
        "template_version": template_version,
        "source_root_hash": root_hash(source_files),
        "installed_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z"),
        "files": dict(sorted(source_files.items())),
    }
    fd, tmp_name = tempfile.mkstemp(prefix=f".{pack}.", suffix=".json", dir=str(path.parent))
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            json.dump(data, handle, indent=2, sort_keys=True)
            handle.write("\n")
        os.replace(tmp_name, path)
    finally:
        if os.path.exists(tmp_name):
            os.unlink(tmp_name)


def list_source_packs(source_root: Path) -> list[str]:
    if not source_root.is_dir():
        return []
    return sorted(path.name for path in source_root.iterdir() if path.is_dir())


def copy_source_to_target(source_dir: Path, target_dir: Path, source_files: dict[str, str]) -> None:
    target_dir.mkdir(parents=True, exist_ok=True)
    for rel in source_files:
        source_path = source_dir / rel
        target_path = target_dir / rel
        target_path.parent.mkdir(parents=True, exist_ok=True)
        tmp_fd, tmp_name = tempfile.mkstemp(prefix=f".{target_path.name}.", dir=str(target_path.parent))
        try:
            with os.fdopen(tmp_fd, "wb") as handle:
                handle.write(source_path.read_bytes())
            os.replace(tmp_name, target_path)
        finally:
            if os.path.exists(tmp_name):
                os.unlink(tmp_name)


def remove_clean_old_files(target_dir: Path, old_files: dict[str, str], new_files: dict[str, str]) -> None:
    for rel in sorted(set(old_files) - set(new_files), reverse=True):
        path = target_dir / rel
        if path.exists() and path.is_file():
            path.unlink()
    for dirpath, dirnames, filenames in os.walk(target_dir, topdown=False):
        if filenames or dirnames:
            continue
        path = Path(dirpath)
        if path != target_dir:
            path.rmdir()


def local_extra_files(target_dir: Path, baseline_files: dict[str, str]) -> list[str]:
    extras: list[str] = []
    if not target_dir.exists():
        return extras
    for path in sorted(target_dir.rglob("*")):
        if not path.is_file():
            continue
        rel = path.relative_to(target_dir).as_posix()
        if rel not in baseline_files:
            extras.append(rel)
    return extras


def classify_pack(target: Path, source_root: Path, pack: str) -> dict:
    source_dir = source_root / pack
    target_dir = target / ".omx/domain-packs" / pack
    if not PACK_NAME_RE.fullmatch(pack):
        return {
            "pack": pack,
            "state": "invalid_pack_name",
            "details": ["pack_name_must_not_contain_path_separators"],
            "source_hash": "",
            "target_hash": "",
            "manifest_hash": "",
            "source_files": {},
            "current_files": {},
            "manifest_files": {},
            "target_dir": target_dir,
            "source_dir": source_dir,
        }
    if not source_dir.is_dir():
        return {
            "pack": pack,
            "state": "unknown_pack",
            "details": [f"source_pack_missing:{source_dir}"],
            "source_hash": "",
            "target_hash": root_hash(file_map(target_dir)) if target_dir.exists() else "",
            "manifest_hash": "",
            "source_files": {},
            "current_files": file_map(target_dir) if target_dir.exists() else {},
            "manifest_files": {},
            "target_dir": target_dir,
            "source_dir": source_dir,
        }
    source_files = file_map(source_dir)
    current_files = file_map(target_dir) if target_dir.exists() else {}
    manifest, manifest_error = read_manifest(target, pack)
    manifest_files = manifest.get("files", {}) if manifest else {}
    manifest_exists = manifest_path(target, pack).exists()

    details: list[str] = []
    state = "current"

    if manifest_error:
        return {
            "pack": pack,
            "state": "conflict",
            "details": [manifest_error],
            "source_files": source_files,
            "current_files": current_files,
            "manifest_files": {},
            "target_dir": target_dir,
            "source_dir": source_dir,
        }

    if not target_dir.exists():
        if manifest_exists:
            state = "deliberately_removed"
            details.append("manifest_exists_target_missing")
        else:
            state = "new_source_pack"
            details.append("not_installed")
    elif not manifest:
        if current_files == source_files:
            state = "adoptable"
            details.append("legacy_no_manifest_exact_source")
        else:
            state = "unmanaged"
            details.append("legacy_no_manifest_differs")
    else:
        extras = local_extra_files(target_dir, manifest_files)
        changed = []
        missing = []
        for rel, baseline_hash in sorted(manifest_files.items()):
            current_hash = current_files.get(rel)
            if current_hash is None:
                missing.append(rel)
            elif current_hash != baseline_hash:
                changed.append(rel)
        if extras or changed or missing:
            state = "conflict"
            if extras:
                details.append("local_extra:" + ",".join(extras))
            if changed:
                details.append("local_modified:" + ",".join(changed))
            if missing:
                details.append("local_missing:" + ",".join(missing))
        elif manifest_files == source_files:
            state = "current"
            details.append("managed_current")
        else:
            state = "outdated_clean"
            removed = sorted(set(manifest_files) - set(source_files))
            added = sorted(set(source_files) - set(manifest_files))
            changed_source = sorted(
                rel for rel in set(source_files).intersection(manifest_files) if source_files[rel] != manifest_files[rel]
            )
            if added:
                details.append("source_added:" + ",".join(added))
            if changed_source:
                details.append("source_changed:" + ",".join(changed_source))
            if removed:
                details.append("source_removed:" + ",".join(removed))

    return {
        "pack": pack,
        "state": state,
        "details": details,
        "source_hash": root_hash(source_files),
        "target_hash": root_hash(current_files),
        "manifest_hash": root_hash(manifest_files),
        "source_files": source_files,
        "current_files": current_files,
        "manifest_files": manifest_files,
        "target_dir": target_dir,
        "source_dir": source_dir,
    }


def refresh_pack(info: dict, target: Path, ai_lab_root: Path) -> str:
    state = info["state"]
    pack = info["pack"]
    if state in {"current", "deliberately_removed"}:
        return state
    if state == "new_source_pack":
        copy_source_to_target(info["source_dir"], info["target_dir"], info["source_files"])
        write_manifest(target, pack, info["source_files"], ai_lab_root)
        return "installed"
    if state == "adoptable":
        write_manifest(target, pack, info["source_files"], ai_lab_root)
        return "adopted"
    if state == "outdated_clean":
        remove_clean_old_files(info["target_dir"], info["manifest_files"], info["source_files"])
        copy_source_to_target(info["source_dir"], info["target_dir"], info["source_files"])
        write_manifest(target, pack, info["source_files"], ai_lab_root)
        return "updated"
    return state


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="ai-domain-pack",
        description="Inspect or refresh ignored AI_AUTO domain-pack references.",
    )
    parser.add_argument("--target", default=".", help="target project path, default: current directory")
    parser.add_argument("--pack", action="append", help="limit to one pack; can be repeated")
    subparsers = parser.add_subparsers(dest="command", required=True)
    status = subparsers.add_parser("status", help="report domain-pack state")
    status.add_argument("--json", action="store_true", help="emit JSON instead of tabular text")
    refresh = subparsers.add_parser("refresh", help="dry-run or apply safe domain-pack refreshes")
    refresh.add_argument("--apply", action="store_true", help="write safe changes; default is dry-run")
    refresh.add_argument("--json", action="store_true", help="emit JSON instead of tabular text")
    return parser.parse_args(argv)


def domain_pack_source_root(ai_lab_root: Path) -> Path:
    override = os.environ.get("AI_AUTO_DOMAIN_PACK_SOURCE_OVERRIDE")
    if override:
        return Path(override).resolve()
    return ai_lab_root / "templates/domain-packs"


def print_text(result: dict) -> None:
    print(f"target: {result['target']}")
    print(f"template_source_branch: {result['template_source_branch']}")
    print(f"template_source_channel: {result['template_source_channel']}")
    print(f"domain_pack_refresh_enabled: {result['domain_pack_refresh_enabled']}")
    print(f"mode: {result['mode']}")
    print("STATE\tPACK\tSOURCE_HASH\tTARGET_HASH\tMANIFEST_HASH\tDETAILS")
    for row in result["packs"]:
        print(
            "\t".join(
                [
                    row["state"],
                    row["pack"],
                    row.get("source_hash", ""),
                    row.get("target_hash", ""),
                    row.get("manifest_hash", ""),
                    ";".join(row.get("details", [])) or "-",
                ]
            )
        )


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    ai_lab_root = resolve_ai_lab_root()
    source_root = domain_pack_source_root(ai_lab_root)
    target = git_root_or_path(Path(args.target))
    branch, channel, refresh_enabled = stable_channel(ai_lab_root)
    packs = args.pack or list_source_packs(source_root)
    if not packs:
        print(f"No domain packs found under: {source_root}", file=sys.stderr)
        return 1

    infos = [classify_pack(target, source_root, pack) for pack in packs]
    result = {
        "target": str(target),
        "template_source_branch": branch,
        "template_source_channel": channel,
        "domain_pack_refresh_enabled": refresh_enabled,
        "mode": args.command,
        "packs": [],
    }

    exit_code = 0
    if any(info["state"] in {"unknown_pack", "invalid_pack_name"} for info in infos):
        exit_code = 1
    if args.command == "refresh" and args.apply and refresh_enabled != "yes":
        exit_code = 1
        for info in infos:
            info = dict(info)
            info["state"] = "blocked"
            info["details"] = list(info["details"]) + ["experimental_source_branch"]
            result["packs"].append(info)
    elif args.command == "refresh" and args.apply:
        for info in infos:
            if info["state"] not in REFRESHABLE_STATES:
                exit_code = 1
                result["packs"].append(info)
                continue
            new_state = refresh_pack(info, target, ai_lab_root)
            refreshed = classify_pack(target, source_root, info["pack"])
            refreshed["state"] = new_state
            if new_state in {"conflict", "unmanaged"}:
                exit_code = 1
            result["packs"].append(refreshed)
    else:
        result["packs"] = infos

    serializable = {
        **result,
        "packs": [
            {key: value for key, value in row.items() if key not in {"source_files", "current_files", "manifest_files", "target_dir", "source_dir"}}
            for row in result["packs"]
        ],
    }
    if getattr(args, "json", False):
        print(json.dumps(serializable, indent=2, sort_keys=True))
    else:
        print_text(serializable)
    return exit_code


if __name__ == "__main__":
    try:
        raise SystemExit(main(sys.argv[1:]))
    except RuntimeError as exc:
        print(f"ai-domain-pack: {exc}", file=sys.stderr)
        raise SystemExit(1)
