#!/usr/bin/env bash
set -euo pipefail

# ai-auto — GLOBAL launcher. Operates ON the PROJECT in $PWD; the engine repo root
# (AI_AUTO_HOME) is this launcher's own grandparent (tools/ is directly under it).
# §4 self-heal guard: resolution never depends on a sourced profile (IDE/git/cron/CI).
AI_AUTO_HOME="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"
# M1: prepend BOTH scripts/ and tools/ (helpers like ai-project-profile/knowledge-capture
# live under tools/) so bare-name helpers resolve in a minimal env, matching install-global.
case ":$PATH:" in *":$AI_AUTO_HOME/scripts:"*) ;; *) PATH="$AI_AUTO_HOME/scripts:$AI_AUTO_HOME/tools:$PATH";; esac
export AI_AUTO_HOME PATH

# R4-1/R3-2: scrub the git env at the TOP of the launcher so EVERY dispatch (gate/verify/
# doctor/setup) resolves the cwd project, never a repo an inherited GIT_DIR points at, and so
# NO inherited git-exec-env var can run arbitrary commands through a git call below. The
# canonical denylist is single-sourced (F1) in hooks/git-scrub.sh and ALSO sourced by the
# engine hooks + the baked shim — one list, no four-copy drift.
# shellcheck source=hooks/git-scrub.sh
. "$AI_AUTO_HOME/hooks/git-scrub.sh"

# Framework files the OLD copy model used to vendor (MANAGED_PATHS from the deleted
# install-automation-template.sh, minus scripts/verify.sh [special] and the retired
# AI_AUTO_TEMPLATE_VERSION marker). scripts/verify.sh is handled separately below.
FRAMEWORK_PATHS=(
  "AGENTS.md"
  "docs/CHROME_CDP_ACCESS.md" "docs/AI_AUTOMATION_TREND_HARDENING.md"
  "docs/research/AI_AUTOMATION_TRENDS.md" "docs/AI_RUNTIME_ADAPTERS.md"
  "docs/AI_PRINCIPAL_RUNTIMES.md" "docs/AI_MODEL_ROUTING.md"
  "docs/AUTOMATION_OPERATING_POLICY.md" "docs/DATA_COMPLETION.md"
  "docs/DEPLOYMENT_COMPLETION.md" "docs/DOMAIN_PACK_AUTHORING_GUIDE.md"
  "docs/DOMAIN_PACKS.md" "docs/INTERVIEW_PLAN_LAYER.md" "docs/INCIDENT_OPS.md"
  "docs/OBSERVABILITY_COMPLETION.md" "docs/OBSIDIAN_INTEGRATION.md"
  "docs/PATCH_NOTES.md" "docs/PERFORMANCE_COMPLETION.md"
  "docs/PLANNING_VISUALIZATION_GUIDE.md" "docs/SECURITY_COMPLETION.md"
  "docs/SESSION_QUALITY_PLAN.md" "docs/UI_COMPLETION.md" "docs/WORKFLOW.md"
  "scripts/archive-omx-artifacts.sh" "scripts/ai-principal-runtime.sh"
  "scripts/ai-runtime-adapter.sh" "scripts/automation-doctor.sh"
  "scripts/audit-obsidian-vault.py" "scripts/benchmark-command.py"
  "scripts/capture-knowledge-drafts.py" "scripts/collect-odoo-docs-kb.py"
  "scripts/collect-review-context.sh" "scripts/docker-config-guard.sh"
  "scripts/git-harden.sh"
  "scripts/doc-budget.sh" "scripts/guidance-duplicate-report.sh"
  "scripts/discover-ai-models.sh" "scripts/knowledge-notes.py"
  "scripts/make-review-prompts.sh" "scripts/record-feedback.sh"
  "scripts/record-project-memory.sh" "scripts/resolve-feedback.sh"
  "scripts/validate-odoo-docs-kb.py" "scripts/run-ai-reviews.sh"
  "scripts/summarize-ai-reviews.sh" "scripts/test-review-summary.sh"
  "scripts/todo-report.py" "scripts/review-gate.sh"
  "scripts/write-session-checkpoint.sh"
)

usage() {
  cat <<'USAGE'
Usage: ai-auto <command> [args]

Commands operate on the project in the current directory ($PWD):
  setup [dir]   adopt global AI_AUTO mode: de-pollute vendored framework files +
                install baked-path hook shims (de-pollutes an already-patched project)
  gate          run the review gate         (review-gate.sh)
  verify        run verification            (verify.sh)
  doctor        diagnose the project        (automation-doctor.sh --project)
USAGE
}

# ai-auto setup [project_dir] — content-aware de-vendor + hook shims. Idempotent.
ai_auto_setup() {
  # F2/R2-3: the git env (GIT_DIR family + the GIT_CONFIG_* injection family) is scrubbed at
  # the TOP of this launcher (see R3-2 above), so every `git` below resolves the cwd project
  # and no inherited core.hooksPath can redirect where shims land.
  local proj="${1:-$PWD}"
  proj="$(cd "$proj" 2>/dev/null && pwd)" || { echo "ai-auto setup: no such directory: ${1:-$PWD}" >&2; return 1; }

  # (a) SELF-HOST GUARD FIRST — before ANY mutation. Never mutate the engine.
  local top
  top="$(git -C "$proj" rev-parse --show-toplevel 2>/dev/null)" \
    || { echo "ai-auto setup: $proj is not inside a git repository." >&2; return 1; }
  # F4: identify an engine checkout by ENGINE-ONLY markers that are NEVER vendored into a
  # project (scripts/verify-machinery.sh AND tools/ai-auto), NOT templates/domain-packs or
  # FRAMEWORK_PATHS members (review-gate.sh) which a legitimate project may carry/author.
  # R3-1: test EXISTENCE (`-f`), not the exec bit (`-x`) — a tarball/zip/`cp`-without-`-p`/
  # core.fileMode=false checkout of the engine can lose `tools/ai-auto`'s exec bit while its
  # CONTENT survives; `-x` would then miss the guard and de-pollute the engine copy.
  if [ "$top" = "$AI_AUTO_HOME" ] \
     || { [ -f "$top/scripts/verify-machinery.sh" ] && [ -f "$top/tools/ai-auto" ]; }; then
    echo "ai-auto setup: ABORT — target ($top) is the AI_AUTO engine repo." >&2
    echo "ai-auto setup: refusing to de-pollute the engine. No changes made." >&2
    return 1
  fi

  # R2-4: serialize concurrent `ai-auto setup` on one project via an advisory lock under
  # the project's .git/ (held for the rest of this run). Degrade gracefully if flock is
  # absent: the atomic `git rm` below is still all-or-nothing, so the worst case is one
  # racer aborting cleanly rather than a half-migrated index.
  # R3-5: lock on the COMMON git dir (not the per-worktree --git-path) so two `ai-auto setup`
  # runs on DIFFERENT worktrees of one repo serialize against the SHARED info/exclude + hooks
  # they both write. (--git-path ai-auto-setup.lock resolves per-worktree -> no mutual excl.)
  local _lockfile _lockfd _lockcommon
  _lockcommon="$(git -C "$top" rev-parse --git-common-dir 2>/dev/null || true)"
  case "$_lockcommon" in "") _lockcommon="$top/.git" ;; /*) : ;; *) _lockcommon="$top/$_lockcommon" ;; esac
  _lockfile="$_lockcommon/ai-auto-setup.lock"
  if command -v flock >/dev/null 2>&1; then
    # NOTE: the 2>/dev/null is SCOPED to the group; a bare `exec ... 2>/dev/null` would
    # redirect the whole shell's stderr permanently and swallow every later message.
    if { exec {_lockfd}>"$_lockfile"; } 2>/dev/null; then
      flock "$_lockfd" 2>/dev/null || true
    fi
  fi

  # F3: DIRTY-INDEX PRE-CHECK — per-file `git rm` under set -e can half-migrate if a
  # managed file has STAGED index content (git rm refuses an index entry that differs from
  # both HEAD and the worktree). Refuse to mutate, BEFORE touching anything, if the index
  # holds any staged ADD/MODIFY/RENAME. (Staged deletions are setup's own footprint from a
  # prior run, so an idempotent re-run is still allowed.)
  if git -C "$top" diff --cached --name-status 2>/dev/null | grep -qvE '^D'; then
    echo "ai-auto setup: ABORT — the git index has staged changes (non-deletions)." >&2
    echo "ai-auto setup: commit or stash them first, then re-run. No changes made." >&2
    return 1
  fi
  echo "ai-auto setup: project=$top  engine=$AI_AUTO_HOME"

  # F5: install the SAFE steps (.omx gitignore + hook shims) BEFORE the destructive
  # `git rm` de-pollution, so a late failure can never leave staged deletions with no
  # hooks installed.
  # (c) ensure .omx/ is gitignored via the project's exclude file.
  local exclude_file
  exclude_file="$(git -C "$top" rev-parse --git-path info/exclude 2>/dev/null || true)"
  case "$exclude_file" in
    "") exclude_file="$top/.git/info/exclude" ;;
    /*) : ;;
    *)  exclude_file="$top/$exclude_file" ;;
  esac
  mkdir -p "$(dirname "$exclude_file")"
  grep -Eq '^[.]omx/?$' "$exclude_file" 2>/dev/null || printf '\n.omx/\n' >> "$exclude_file"

  # (d) install THIN hook shims with the engine path BAKED at setup time (readlink -f).
  # Fail-closed: never clobber a pre-existing NON-shim hook.
  local hooks_dir baked hook dst
  hooks_dir="$(git -C "$top" rev-parse --git-path hooks 2>/dev/null || true)"
  case "$hooks_dir" in /*) : ;; *) hooks_dir="$top/$hooks_dir" ;; esac
  baked="$(readlink -f "$AI_AUTO_HOME")"
  if [ -n "$hooks_dir" ]; then
    mkdir -p "$hooks_dir"
    for hook in pre-commit post-commit; do
      dst="$hooks_dir/$hook"
      # Leave a genuinely custom hook untouched. BUT a project onboarded under the OLD
      # copy model has the FULL engine hook body in .git/hooks (no 'AI_AUTO shim' marker);
      # R4-5: recognize those framework-owned legacy bodies by their stable engine markers
      # ('AI_AUTO worktree-safe hook' / 'AI_AUTO post-commit guard') and UPGRADE them to the
      # current scrubbing shim instead of leaving the stale (unscrubbing) copy in place.
      if [ -e "$dst" ] \
         && ! grep -q 'AI_AUTO shim' "$dst" 2>/dev/null \
         && ! grep -qE 'AI_AUTO (worktree-safe hook|post-commit guard)' "$dst" 2>/dev/null; then
        echo "ai-auto setup: WARNING existing custom $hook left untouched: $dst (merge manually)" >&2
        continue
      fi
      cat > "$dst" <<EOF
#!/usr/bin/env bash
# AI_AUTO shim — baked engine path (do not edit; re-run 'ai-auto setup' to refresh).
# R4-1/R3-3: scrub the CANONICAL git-exec-env denylist before running the engine hook — an
# inherited GIT_EXTERNAL_DIFF / core.fsmonitor / core.hooksPath (via GIT_CONFIG_KEY_*/VALUE_*)
# or any command-exec git var is arbitrary-command execution through a shimmed commit. F1: the
# list is single-sourced from the baked engine's hooks/git-scrub.sh — NO inline copy here.
AI_AUTO_HOME="$baked"
if [ -f "\$AI_AUTO_HOME/hooks/git-scrub.sh" ]; then
  . "\$AI_AUTO_HOME/hooks/git-scrub.sh"
fi
# F1/R2-1: if the baked engine hook was moved/renamed/reinstalled elsewhere — or the path
# now exists but is a DIRECTORY (or any non-regular-file) — DO NOT exec it (bash would say
# "Is a directory" / exit 126-127 and ABORT the user's commit). Require a regular,
# executable FILE; otherwise warn loudly + exit 0.
if ! [ -f "\$AI_AUTO_HOME/hooks/$hook" ] || ! [ -x "\$AI_AUTO_HOME/hooks/$hook" ]; then
  printf '[$hook] WARNING: AI_AUTO engine hook missing or not a runnable file (%s); re-run '\''ai-auto setup'\''. NOT blocking commit.\n' "\$AI_AUTO_HOME/hooks/$hook" >&2
  exit 0
fi
PATH="\$AI_AUTO_HOME/scripts:\$AI_AUTO_HOME/tools:\$PATH"
exec "\$AI_AUTO_HOME/hooks/$hook" "\$@"
EOF
      chmod +x "$dst"
    done
  fi

  # (e) domain detect (advisory machine-local; no-op if not applicable).
  # R5-4: the setup lock fd was opened non-CLOEXEC (`exec {_lockfd}>`), so a long-lived
  # grandchild (e.g. a daemon this advisory helper spawns) would inherit it and hold the
  # advisory lock after setup exits — blocking the next `ai-auto setup`. Close the lock fd
  # in THIS child so it cannot leak past setup. (Other post-lock children are short-lived
  # git calls with core.fsmonitor scrubbed, so they spawn no daemon.)
  if command -v ai-project-profile >/dev/null 2>&1; then
    if [ -n "${_lockfd:-}" ]; then
      ai-project-profile write "$top" >/dev/null 2>&1 {_lockfd}>&- || true
    else
      ai-project-profile write "$top" >/dev/null 2>&1 || true
    fi
  fi

  # (b) CONTENT-AWARE de-pollution (LAST — the only destructive step; see F5): pristine
  # vendored copy -> mark for removal; differs (or no global pristine, or a symlink, or a
  # local worktree edit) -> LEAVE + report. NEVER delete a differing/symlinked file.
  # R2-2/R2-4: build the FULL safe-to-remove set first, EXCLUDING any path with a local
  # worktree modification (worktree != index), then remove the whole set in ONE atomic
  # `git rm -- "${removed[@]}"`. git validates every pathspec up front and removes NONE on
  # any error, so there is no per-file half-migration (R2-2) and no partial state under a
  # concurrent race (R2-4); a worktree-modified managed file is treated as customized/kept
  # and is never handed to git rm.
  local removed=() kept=() f pristine
  for f in "${FRAMEWORK_PATHS[@]}"; do
    git -C "$top" ls-files --error-unmatch "$f" >/dev/null 2>&1 || continue
    # F6: cmp follows symlinks and ignores file type/mode; a deliberately-symlinked
    # managed path whose target bytes equal pristine would be wrongly git-rm'd. Skip
    # non-regular tracked entries and keep them.
    if [ -L "$top/$f" ]; then kept+=("$f (symlink — left untouched)"); continue; fi
    pristine="$AI_AUTO_HOME/$f"
    # R2-2: `git diff --quiet -- f` fails (non-zero) when the worktree differs from the
    # index/HEAD; such a file would make a no-`--cached` `git rm` error, so KEEP it.
    if [ -f "$pristine" ] && cmp -s "$top/$f" "$pristine" && git -C "$top" diff --quiet -- "$f"; then
      removed+=("$f")
    else
      kept+=("$f")
    fi
  done
  # scripts/verify.sh is special: identical to engine default -> safe pristine, remove;
  # differs (or symlinked, or worktree-modified) -> LEAVE (human converts it to
  # scripts/verify-project.sh).
  if git -C "$top" ls-files --error-unmatch scripts/verify.sh >/dev/null 2>&1; then
    if [ -L "$top/scripts/verify.sh" ]; then
      kept+=("scripts/verify.sh (symlink — left untouched)")
    elif [ -f "$AI_AUTO_HOME/scripts/verify.sh" ] && cmp -s "$top/scripts/verify.sh" "$AI_AUTO_HOME/scripts/verify.sh" \
         && git -C "$top" diff --quiet -- scripts/verify.sh; then
      removed+=("scripts/verify.sh")
    else
      kept+=("scripts/verify.sh (customized — convert to scripts/verify-project.sh by hand)")
    fi
  fi
  # Atomic removal of the whole safe set (all-or-nothing; see R2-2/R2-4 above).
  if ((${#removed[@]})); then
    git -C "$top" rm --quiet -- "${removed[@]}"
  fi

  # (f) report; do NOT auto-commit. The git rm's are already staged.
  echo
  echo "Removed (pristine vendored copies, STAGED for deletion): ${#removed[@]}"
  ((${#removed[@]})) && printf '  - %s\n' "${removed[@]}"
  echo "Kept (customized — review): ${#kept[@]}"
  ((${#kept[@]})) && printf '  ~ %s\n' "${kept[@]}"
  echo
  echo "Hook shims (baked engine $baked) in: $hooks_dir"
  if ((${#removed[@]})); then
    echo "Review, then commit the de-pollution:"
    echo "  git -C \"$top\" commit -m 'adopt global AI_AUTO mode: drop vendored framework files'"
  else
    echo "Nothing to remove (already migrated); hooks + .omx gitignore re-asserted. exit 0"
  fi
}

cmd="${1:-}"
shift || true
case "$cmd" in
  gate)   exec "$AI_AUTO_HOME/scripts/review-gate.sh" "$@" ;;
  verify) exec "$AI_AUTO_HOME/scripts/verify.sh" "$@" ;;
  doctor) case "${1:-}" in --home|--project) exec "$AI_AUTO_HOME/scripts/automation-doctor.sh" "$@" ;; *) exec "$AI_AUTO_HOME/scripts/automation-doctor.sh" --project "$@" ;; esac ;;
  setup)  ai_auto_setup "$@" ;;
  -h|--help) usage ;;
  "")     usage >&2; exit 1 ;;
  *)      echo "ai-auto: unknown command: $cmd" >&2; usage >&2; exit 2 ;;
esac
