#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  LINK_TARGET="$(readlink "$SOURCE")"
  case "$LINK_TARGET" in
    /*)
      SOURCE="$LINK_TARGET"
      ;;
    *)
      SOURCE="${SOURCE_DIR}/${LINK_TARGET}"
      ;;
  esac
done

TOOL_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
AI_LAB_ROOT="$(cd "${TOOL_DIR}/.." && pwd)"
INSTALLER="${AI_LAB_ROOT}/scripts/install-automation-template.sh"
TARGET_DIR="${1:-$(pwd)}"

case "${1:-}" in
  -h|--help)
    echo "Usage: aiinit [target-repo]"
    echo
    echo "Install the automation template into a target git repository."
    echo "When target-repo is omitted, the current directory is used."
    echo "The ai-lab checkout is resolved from this command's real path."
    echo
    echo "Example:"
    echo "  cd ~/workspace/my-project"
    echo "  aiinit"
    echo "  aiinit ~/workspace/my-project"
    exit 0
    ;;
esac

if [ ! -x "$INSTALLER" ]; then
  echo "Installer not found or not executable: $INSTALLER"
  exit 1
fi

"$INSTALLER" "$TARGET_DIR"

echo
echo "Running automation doctor for: ${TARGET_DIR}"
(
  cd "$TARGET_DIR" || exit 1
  DOCTOR_SKIP_DIRTY_CHECK=1 ./scripts/automation-doctor.sh
)

cat <<'NEXT'

Next AI request:
  프로젝트 초기설정 해줘

Equivalent detailed request:
  프로젝트 요구사항 인터뷰하고 AGENTS.md, docs/WORKFLOW.md, scripts/verify.sh를 프로젝트에 맞게 설정해줘

This starts the required onboarding pass: interview the project owner, treat
existing materials as references when relevant, update the generated automation
files, then run automation-doctor, verify, and review-gate before reporting.
NEXT
