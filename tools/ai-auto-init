#!/usr/bin/env bash
set -euo pipefail

# Legacy onboarding entrypoint. The per-project COPY model it drove (vendoring
# framework files into a target repo) was removed in the global-tool-ization:
# AI_AUTO is now a globally installed tool that operates ON a project directory,
# and a project repo carries ZERO vendored framework files. Project setup is
# handled by the global `ai-auto` workflow; this command no longer copies anything.

case "${1:-}" in
  -h|--help)
    cat <<'USAGE'
Usage: aiinit [target-repo]

The copy-based onboarding (vendoring framework files into a project) has been
retired. AI_AUTO is now a global tool that runs against a project directory with
no vendored framework files. Use the global `ai-auto` workflow for project setup.
USAGE
    exit 0
    ;;
esac

echo "aiinit: the copy-based onboarding was retired in the global-tool-ization." >&2
echo "AI_AUTO now runs globally against a project with no vendored framework files." >&2
echo "Use the global 'ai-auto' workflow for project setup." >&2
exit 1
