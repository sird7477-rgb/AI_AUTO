#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  LINK_TARGET="$(readlink "$SOURCE")"
  case "$LINK_TARGET" in
    /*)
      SOURCE="$LINK_TARGET"
      ;;
    *)
      SOURCE="${SOURCE_DIR}/${LINK_TARGET}"
      ;;
  esac
done

TOOL_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
AI_LAB_ROOT="$(cd "${TOOL_DIR}/.." && pwd)"
TEMPLATE_DIR="${AI_LAB_ROOT}/templates/automation-base"
VERSION_FILE="AI_AUTO_TEMPLATE_VERSION"
RECORD_FEEDBACK=0
JSON=0
TARGET_DIR=""

usage() {
  cat <<'USAGE'
Usage: ai-auto-template-status [--record-feedback] [--json] [target-repo]

Compare a project against the current AI_AUTO automation template.

This command reports status only. It does not merge or patch files.
Generated/runtime files such as .omx/ logs, reviewer state, and external review
artifacts are intentionally outside the managed-file manifest.

Options:
  --record-feedback   record a sanitized feedback queue item when drift exists
  --json              emit machine-readable JSON (per-file state + ownership, counts,
                      installed/current version) instead of the text report
  -h, --help          show this help

Examples:
  ai-auto-template-status
  ai-auto-template-status /path/to/project
  ai-auto-template-status --record-feedback /path/to/project
USAGE
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --record-feedback)
      RECORD_FEEDBACK=1
      shift
      ;;
    --json)
      JSON=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "Unknown option: $1"
      echo
      usage
      exit 2
      ;;
    *)
      if [ -n "$TARGET_DIR" ]; then
        echo "Unexpected extra argument: $1"
        echo
        usage
        exit 2
      fi
      TARGET_DIR="$1"
      shift
      ;;
  esac
done

if [ "$#" -gt 0 ]; then
  if [ -n "$TARGET_DIR" ]; then
    echo "Unexpected extra argument: $1"
    echo
    usage
    exit 2
  fi
  TARGET_DIR="$1"
fi

TARGET_DIR="${TARGET_DIR:-$(pwd)}"

if [ ! -d "$TARGET_DIR" ]; then
  echo "Target directory does not exist: ${TARGET_DIR}"
  exit 1
fi

if [ ! -d "$TEMPLATE_DIR" ]; then
  echo "Template directory not found: ${TEMPLATE_DIR}"
  exit 1
fi

if ! command -v sha256sum >/dev/null 2>&1; then
  echo "sha256sum is required"
  exit 1
fi

target_abs="$(cd "$TARGET_DIR" && pwd -P)"
current_version="$(sed -n '1p' "${TEMPLATE_DIR}/${VERSION_FILE}" 2>/dev/null || true)"
installed_version="$(sed -n '1p' "${target_abs}/${VERSION_FILE}" 2>/dev/null || true)"
SOURCE_CHECKOUT=0
if [ "$target_abs" = "$(cd "${AI_LAB_ROOT}" && pwd -P)" ]; then
  SOURCE_CHECKOUT=1
  installed_version="${current_version}"
fi

if [ -z "$current_version" ]; then
  echo "Current template version is missing: ${TEMPLATE_DIR}/${VERSION_FILE}"
  exit 1
fi

same_count=0
different_count=0
missing_count=0
total_count=0
rows=""

# Install-time baseline (.ai-auto/template-manifest.json, written by aiinit): sha of each
# managed file AS INSTALLED. Enables the 3-way drift classification below (source / installed
# / baseline) so a project edit is distinguished from an upstream change.
declare -A BASELINE_SHA
manifest_json="${target_abs}/.ai-auto/template-manifest.json"
if [ -f "$manifest_json" ]; then
  while IFS=$'\t' read -r _bpath _bsha; do
    [ -n "$_bpath" ] && BASELINE_SHA["$_bpath"]="$_bsha"
  done < <(python3 -c '
import json, sys
try:
    d = json.load(open(sys.argv[1]))
except Exception:
    sys.exit(0)
for p, sh in (d.get("files") or {}).items():
    print(f"{p}\t{sh}")
' "$manifest_json" 2>/dev/null)
fi

source_branch() {
  if [ -n "${AI_AUTO_TEMPLATE_SOURCE_BRANCH_OVERRIDE:-}" ]; then
    printf '%s\n' "${AI_AUTO_TEMPLATE_SOURCE_BRANCH_OVERRIDE}"
    return 0
  fi

  git -C "${AI_LAB_ROOT}" rev-parse --abbrev-ref HEAD 2>/dev/null || printf 'unknown\n'
}

template_source_branch="$(source_branch)"
case "${template_source_branch}" in
  main)
    template_source_channel="stable"
    template_patch_enabled="yes"
    template_patch_block_reason="none"
    ;;
  *)
    template_source_channel="experimental"
    template_patch_enabled="no"
    template_patch_block_reason="experimental_source_branch"
    ;;
esac

managed_files() {
  cat <<'FILES'
AI_AUTO_TEMPLATE_VERSION|AI_AUTO_TEMPLATE_VERSION|template-owned|update
AGENTS.md|AGENTS.md|hybrid|review-merge
docs/CHROME_CDP_ACCESS.md|docs/CHROME_CDP_ACCESS.md|template-owned|update
docs/AI_AUTOMATION_TREND_HARDENING.md|docs/AI_AUTOMATION_TREND_HARDENING.md|template-owned|update
docs/research/AI_AUTOMATION_TRENDS.md|docs/research/AI_AUTOMATION_TRENDS.md|template-owned|update
docs/AI_RUNTIME_ADAPTERS.md|docs/AI_RUNTIME_ADAPTERS.md|template-owned|update
docs/AI_PRINCIPAL_RUNTIMES.md|docs/AI_PRINCIPAL_RUNTIMES.md|template-owned|update
docs/AI_MODEL_ROUTING.md|docs/AI_MODEL_ROUTING.md|template-owned|update
docs/AUTOMATION_OPERATING_POLICY.md|docs/AUTOMATION_OPERATING_POLICY.md|template-owned|update
docs/DATA_COMPLETION.md|docs/DATA_COMPLETION.md|template-owned|update
docs/DEPLOYMENT_COMPLETION.md|docs/DEPLOYMENT_COMPLETION.md|template-owned|update
docs/DOMAIN_PACK_AUTHORING_GUIDE.md|docs/DOMAIN_PACK_AUTHORING_GUIDE.md|template-owned|update
docs/DOMAIN_PACKS.md|docs/DOMAIN_PACKS.md|template-owned|update
docs/INTERVIEW_PLAN_LAYER.md|docs/INTERVIEW_PLAN_LAYER.md|template-owned|update
docs/INCIDENT_OPS.md|docs/INCIDENT_OPS.md|template-owned|update
docs/OBSERVABILITY_COMPLETION.md|docs/OBSERVABILITY_COMPLETION.md|template-owned|update
docs/OBSIDIAN_INTEGRATION.md|docs/OBSIDIAN_INTEGRATION.md|template-owned|update
docs/PATCH_NOTES.md|docs/PATCH_NOTES.md|template-owned|update
docs/PERFORMANCE_COMPLETION.md|docs/PERFORMANCE_COMPLETION.md|template-owned|update
docs/PLANNING_VISUALIZATION_GUIDE.md|docs/PLANNING_VISUALIZATION_GUIDE.md|template-owned|update
docs/SECURITY_COMPLETION.md|docs/SECURITY_COMPLETION.md|template-owned|update
docs/SESSION_QUALITY_PLAN.md|docs/SESSION_QUALITY_PLAN.md|template-owned|update
docs/UI_COMPLETION.md|docs/UI_COMPLETION.md|template-owned|update
docs/WORKFLOW.md|docs/WORKFLOW.md|hybrid|review-merge
scripts/archive-omx-artifacts.sh|scripts/archive-omx-artifacts.sh|template-owned|update
scripts/ai-principal-runtime.sh|scripts/ai-principal-runtime.sh|template-owned|update
scripts/ai-runtime-adapter.sh|scripts/ai-runtime-adapter.sh|template-owned|update
scripts/automation-doctor.sh|scripts/automation-doctor.sh|template-owned|update
scripts/benchmark-command.py|scripts/benchmark-command.py|template-owned|update
scripts/capture-knowledge-drafts.py|scripts/capture-knowledge-drafts.py|template-owned|update
scripts/collect-review-context.sh|scripts/collect-review-context.sh|template-owned|update
scripts/docker-config-guard.sh|scripts/docker-config-guard.sh|template-owned|update
scripts/discover-ai-models.sh|scripts/discover-ai-models.sh|template-owned|update
scripts/knowledge-notes.py|scripts/knowledge-notes.py|template-owned|update
scripts/make-review-prompts.sh|scripts/make-review-prompts.sh|template-owned|update
scripts/record-feedback.sh|scripts/record-feedback.sh|template-owned|update
scripts/record-project-memory.sh|scripts/record-project-memory.sh|template-owned|update
scripts/resolve-feedback.sh|scripts/resolve-feedback.sh|template-owned|update
scripts/validate-odoo-docs-kb.py|scripts/validate-odoo-docs-kb.py|template-owned|update
scripts/run-ai-reviews.sh|scripts/run-ai-reviews.sh|template-owned|update
scripts/summarize-ai-reviews.sh|scripts/summarize-ai-reviews.sh|template-owned|update
scripts/test-review-summary.sh|scripts/test-review-summary.sh|template-owned|update
scripts/todo-report.py|scripts/todo-report.py|template-owned|update
scripts/review-gate.sh|scripts/review-gate.sh|template-owned|update
scripts/write-session-checkpoint.sh|scripts/write-session-checkpoint.sh|template-owned|update
scripts/verify.sh|scripts/verify.example.sh|project-owned|inspect-only
FILES
}

hash_file() {
  sha256sum "$1" | awk '{print $1}'
}

source_checkout_target_only() {
  [ "$SOURCE_CHECKOUT" -eq 1 ] || return 1
  case "$1" in
    AI_AUTO_TEMPLATE_VERSION|docs/PATCH_NOTES.md)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

while IFS='|' read -r target_path template_path ownership patch_policy; do
  [ -n "$target_path" ] || continue
  ownership="${ownership:-template-owned}"
  patch_policy="${patch_policy:-update}"

  total_count=$((total_count + 1))
  source_path="${TEMPLATE_DIR}/${template_path}"
  project_path="${target_abs}/${target_path}"

  if [ ! -f "$source_path" ]; then
    echo "Template managed file missing: ${template_path}"
    exit 1
  fi

  source_sha="$(hash_file "$source_path")"
  baseline_sha="${BASELINE_SHA[$target_path]:-}"
  if source_checkout_target_only "$target_path"; then
    state="source-only"; drift="in_sync"
    same_count=$((same_count + 1))
  elif [ ! -f "$project_path" ]; then
    state="missing"; drift="missing"
    missing_count=$((missing_count + 1))
  else
    installed_sha="$(hash_file "$project_path")"
    if [ "$source_sha" = "$installed_sha" ]; then
      state="same"; drift="in_sync"
      same_count=$((same_count + 1))
    else
      state="different"
      different_count=$((different_count + 1))
      if [ -z "$baseline_sha" ]; then
        drift="no_baseline"        # pre-manifest install: cannot tell edit from upstream
      elif [ "$installed_sha" = "$baseline_sha" ]; then
        drift="outdated"           # home moved on, no local edit -> safe to refresh
      elif [ "$source_sha" = "$baseline_sha" ]; then
        drift="locally_edited"     # project edited, upstream unchanged
      else
        drift="conflict"           # both changed since install
      fi
    fi
  fi

  rows="${rows}${state}	${target_path}	${template_path}	${ownership}	${patch_policy}	${drift}
"
done <<EOF
$(managed_files)
EOF

if [ "$SOURCE_CHECKOUT" -eq 1 ]; then
  overall_status="source_checkout"
elif [ -z "$installed_version" ]; then
  overall_status="missing_version"
elif [ "$installed_version" != "$current_version" ] || [ "$different_count" -gt 0 ] || [ "$missing_count" -gt 0 ]; then
  overall_status="customized_or_outdated"
else
  overall_status="current"
fi

if [ "$JSON" -eq 1 ]; then
  # Machine-readable surface for the downstream staleness gate: per-file {state, ownership,
  # patch_policy} so the gate can block on ownership==template-owned only. Serialized via
  # python3 for correct escaping; rows arrive on stdin as STATE\tPATH\tTEMPLATE\tOWN\tPOLICY.
  printf '%s' "${rows}" | \
    AAS_TARGET="$target_abs" \
    AAS_IV="${installed_version:-}" \
    AAS_CV="${current_version:-}" \
    AAS_STATUS="$overall_status" \
    AAS_BRANCH="${template_source_branch:-}" \
    AAS_CHANNEL="${template_source_channel:-}" \
    AAS_PATCH_ENABLED="${template_patch_enabled:-}" \
    AAS_PATCH_REASON="${template_patch_block_reason:-}" \
    AAS_TOTAL="$total_count" AAS_SAME="$same_count" \
    AAS_DIFF="$different_count" AAS_MISSING="$missing_count" \
    python3 -c '
import json, os, sys
files = []
for line in sys.stdin.read().splitlines():
    if not line.strip():
        continue
    parts = line.split("\t")
    if len(parts) < 6:
        continue
    st, path, tpath, own, pol, drift = parts[:6]
    files.append({"state": st, "path": path, "template_path": tpath,
                  "ownership": own, "patch_policy": pol, "drift": drift})
out = {
    "target": os.environ["AAS_TARGET"],
    "installed_version": os.environ.get("AAS_IV") or None,
    "current_version": os.environ.get("AAS_CV") or None,
    "status": os.environ["AAS_STATUS"],
    "template_source_branch": os.environ.get("AAS_BRANCH") or None,
    "template_source_channel": os.environ.get("AAS_CHANNEL") or None,
    "template_patch_enabled": os.environ.get("AAS_PATCH_ENABLED") or None,
    "template_patch_block_reason": os.environ.get("AAS_PATCH_REASON") or None,
    "counts": {
        "managed_files": int(os.environ["AAS_TOTAL"]),
        "same": int(os.environ["AAS_SAME"]),
        "different": int(os.environ["AAS_DIFF"]),
        "missing": int(os.environ["AAS_MISSING"]),
    },
    "files": files,
}
print(json.dumps(out, indent=2))
'
  exit 0
fi

cat <<REPORT
AI_AUTO Template Status
target: ${target_abs}
installed_version: ${installed_version:-missing}
current_version: ${current_version}
status: ${overall_status}
template_source_branch: ${template_source_branch}
template_source_channel: ${template_source_channel}
template_patch_enabled: ${template_patch_enabled}
template_patch_block_reason: ${template_patch_block_reason}
managed_files: ${total_count}
same: ${same_count}
different: ${different_count}
missing: ${missing_count}

STATE	PATH	TEMPLATE_PATH	OWNERSHIP	PATCH_POLICY	DRIFT
${rows}
REPORT

if [ "$RECORD_FEEDBACK" -eq 1 ]; then
  if [ "$overall_status" = "current" ]; then
    echo "feedback: skipped current"
  elif [ -x "${AI_LAB_ROOT}/scripts/record-feedback.sh" ]; then
    OMX_FEEDBACK_QUEUE_FILE="${target_abs}/.omx/feedback/queue.jsonl" \
      "${AI_LAB_ROOT}/scripts/record-feedback.sh" \
        --type improvement \
        --repeat-key automation-template:update-available \
        --summary "AI_AUTO automation template status differs from the current template" \
        --severity medium \
        --surface automation-template \
        --resolution "Run ai-auto-template-status, review the reported file differences, patch manually if appropriate, then run scripts/refresh-guidance-baseline.sh <target> to refresh the guidance baseline" \
        --source ai-auto-template-status >/dev/null
    echo "feedback: recorded automation-template:update-available"
  else
    echo "feedback: skipped missing AI_AUTO scripts/record-feedback.sh"
  fi
fi
