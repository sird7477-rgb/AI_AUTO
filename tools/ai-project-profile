#!/usr/bin/env python3
"""Project domain profile — detect a repo's domain from repo signals and record it in
.omx/project-profile.json (machine-local, gitignored).

Auto-detection is PRIMARY (zero-friction): an Odoo project is a repo with a `custom-addons/`
directory containing module `__manifest__.py` files (the same signal the pre-push hook uses).
aiinit may CONFIRM the profile and add metadata (version, addons) that detection can't infer.

Read by the retrieval hook (Stage 1B) to gate domain retrieval; written by aiinit and on demand.

Usage:
  ai-project-profile detect [repo]        print detected domain (no write); exit 0 if a domain
                                          is detected, 3 if none
  ai-project-profile write  [repo]        detect + write .omx/project-profile.json (merging any
                                          existing confirmed fields); prints the path
  ai-project-profile read   [repo]        print the stored profile JSON (exit 3 if absent)
  ai-project-profile domain [repo]        print just the domain (stored, else detected, else empty)

The profile is advisory machine-local metadata; it changes no project behaviour on its own.
"""
from __future__ import annotations

import glob
import json
import os
import re
import subprocess
import sys
from datetime import datetime, timezone

PROFILE_REL = os.path.join(".omx", "project-profile.json")


def repo_root(arg: str | None) -> str:
    if arg:
        return os.path.abspath(arg)
    try:
        out = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True,
        )
        top = out.stdout.strip()
        if top:
            return top
    except Exception:
        pass
    return os.getcwd()


def detect_odoo(repo: str) -> bool:
    """An Odoo project = custom-addons/ holding at least one module __manifest__.py."""
    addons = os.path.join(repo, "custom-addons")
    if not os.path.isdir(addons):
        return False
    for _ in glob.iglob(os.path.join(addons, "*", "__manifest__.py")):
        return True
    return False


def detect_domain(repo: str) -> str:
    # Registry is intentionally tiny; add a domain here only when it has a rich KB.
    if detect_odoo(repo):
        return "odoo"
    return ""


def odoo_version(repo: str) -> str:
    """Best-effort major.minor from any custom-addons manifest (e.g. 19.0)."""
    for manifest in sorted(glob.glob(os.path.join(repo, "custom-addons", "*", "__manifest__.py"))):
        try:
            text = open(manifest, encoding="utf-8", errors="replace").read()
        except OSError:
            continue
        m = re.search(r"['\"]version['\"]\s*:\s*['\"]\s*(\d+\.\d+)", text)
        if m:
            return m.group(1)
    return ""


def odoo_addons(repo: str) -> list[str]:
    names = set()
    for manifest in glob.glob(os.path.join(repo, "custom-addons", "*", "__manifest__.py")):
        names.add(os.path.basename(os.path.dirname(manifest)))
    return sorted(names)


def now_iso() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def load_profile(repo: str) -> dict | None:
    path = os.path.join(repo, PROFILE_REL)
    if not os.path.isfile(path):
        return None
    try:
        return json.load(open(path, encoding="utf-8"))
    except (OSError, ValueError):
        return None


def cmd_detect(repo: str) -> int:
    d = detect_domain(repo)
    if d:
        print(d)
        return 0
    print("", end="")
    return 3


def cmd_write(repo: str) -> int:
    domain = detect_domain(repo)
    if not domain:
        sys.stderr.write(f"[project-profile] no known domain detected at {repo}\n")
        return 3
    existing = load_profile(repo) or {}
    profile = {
        "schema": 1,
        "domain": domain,
        "version": odoo_version(repo) if domain == "odoo" else existing.get("version", ""),
        "addons": odoo_addons(repo) if domain == "odoo" else existing.get("addons", []),
        # Preserve an explicit confirmation (e.g. from an aiinit interview) if present.
        "detected_by": "auto" if not existing.get("confirmed_at") else existing.get("detected_by", "auto"),
        "confirmed_at": existing.get("confirmed_at", ""),
        "updated_at": now_iso(),
    }
    omx = os.path.join(repo, ".omx")
    path = os.path.join(repo, PROFILE_REL)
    tmp = path + ".tmp"
    # H5: a hostile cloned repo can pre-plant `.omx`, the target, or the `.tmp` path as a
    # symlink escaping the repo (git stores the target verbatim). A naive `open(tmp,"w")`
    # FOLLOWS it and truncates+overwrites an arbitrary victim. Refuse every symlinked seam
    # and open the temp with O_NOFOLLOW|O_EXCL so a link planted after the check (TOCTOU) is
    # rejected (ELOOP/EEXIST) rather than followed. Surface the refusal — never mask it.
    if os.path.islink(omx):
        sys.stderr.write(f"[project-profile] REFUSING: {omx} is a symlink (won't write through it)\n")
        return 1
    try:
        os.makedirs(omx, exist_ok=True)
    except OSError as exc:
        sys.stderr.write(f"[project-profile] REFUSING: cannot create {omx}: {exc}\n")
        return 1
    if os.path.islink(omx) or not os.path.isdir(omx):
        sys.stderr.write(f"[project-profile] REFUSING: {omx} is not a real directory\n")
        return 1
    if os.path.islink(path) or os.path.islink(tmp):
        sys.stderr.write(f"[project-profile] REFUSING: {path} or {tmp} is a symlink\n")
        return 1
    # R23: O_NOFOLLOW guards only the FINAL component, so `.omx` itself could be swapped to a
    # symlink between the checks above and the open (parent-dir TOCTOU). Pin the parent by opening
    # it with O_DIRECTORY|O_NOFOLLOW, then create/replace the temp RELATIVE TO THAT fd (openat) so
    # the whole path is symlink-safe: a post-check swap of `.omx` cannot redirect the write.
    tmp_name = os.path.basename(tmp)
    final_name = os.path.basename(path)
    try:
        dir_fd = os.open(omx, os.O_RDONLY | os.O_DIRECTORY | os.O_NOFOLLOW)
    except OSError as exc:
        sys.stderr.write(f"[project-profile] REFUSING: cannot open {omx} as a real directory: {exc}\n")
        return 1
    try:
        # Clear only a stale NON-symlink temp; a planted symlink is refused above, never removed.
        if os.path.lexists(tmp) and not os.path.islink(tmp):
            try:
                os.remove(tmp_name, dir_fd=dir_fd)
            except OSError:
                pass
        data = json.dumps(profile, ensure_ascii=False, indent=2, sort_keys=True) + "\n"
        try:
            fd = os.open(tmp_name, os.O_WRONLY | os.O_CREAT | os.O_EXCL | os.O_NOFOLLOW, 0o600,
                         dir_fd=dir_fd)
        except OSError as exc:
            sys.stderr.write(f"[project-profile] REFUSING to write temp {tmp}: {exc}\n")
            return 1
        try:
            with os.fdopen(fd, "w", encoding="utf-8") as fh:
                fh.write(data)
            os.replace(tmp_name, final_name, src_dir_fd=dir_fd, dst_dir_fd=dir_fd)
        except OSError as exc:
            try:
                os.remove(tmp_name, dir_fd=dir_fd)
            except OSError:
                pass
            sys.stderr.write(f"[project-profile] write failed for {path}: {exc}\n")
            return 1
    finally:
        os.close(dir_fd)
    print(path)
    return 0


def cmd_read(repo: str) -> int:
    profile = load_profile(repo)
    if profile is None:
        sys.stderr.write(f"[project-profile] no profile at {os.path.join(repo, PROFILE_REL)}\n")
        return 3
    json.dump(profile, sys.stdout, ensure_ascii=False, indent=2, sort_keys=True)
    sys.stdout.write("\n")
    return 0


def cmd_domain(repo: str) -> int:
    profile = load_profile(repo)
    if profile and profile.get("domain"):
        print(profile["domain"])
        return 0
    d = detect_domain(repo)
    if d:
        print(d)
        return 0
    return 3


def main(argv: list[str]) -> int:
    cmd = argv[1] if len(argv) > 1 else "read"
    repo = repo_root(argv[2] if len(argv) > 2 else None)
    handlers = {
        "detect": cmd_detect,
        "write": cmd_write,
        "read": cmd_read,
        "domain": cmd_domain,
    }
    handler = handlers.get(cmd)
    if handler is None:
        sys.stderr.write(
            "usage: ai-project-profile {detect|write|read|domain} [repo]\n"
        )
        return 2
    return handler(repo)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
