#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  -h|--help)
    echo "Usage: workspace-scan [workspace-path]"
    echo
    echo "Scans git repositories under a workspace directory and aiinit registry."
    echo
    echo "Default workspace:"
    echo "  ~/workspace"
    echo
    echo "Registry:"
    echo "  ~/.local/state/ai-auto/projects.tsv"
    echo "  override with AI_AUTO_PROJECT_REGISTRY_FILE=/path/to/projects.tsv"
    echo
    echo "Examples:"
    echo "  workspace-scan"
    echo "  workspace-scan ~/workspace"
    exit 0
    ;;
esac

WORKSPACE="${1:-$HOME/workspace}"
STATE_ROOT="${XDG_STATE_HOME:-${HOME:-}/.local/state}"
PROJECT_REGISTRY="${AI_AUTO_PROJECT_REGISTRY_FILE:-${STATE_ROOT}/ai-auto/projects.tsv}"

if [ ! -d "$WORKSPACE" ]; then
  echo "Workspace not found: $WORKSPACE"
  exit 1
fi

declare -A REGISTERED_PATHS
declare -A PRINTED_PATHS

if [ -f "$PROJECT_REGISTRY" ]; then
  while IFS=$'\t' read -r _registered_at path _name _branch _origin; do
    [ -n "$path" ] || continue
    REGISTERED_PATHS["$path"]=1
  done < "$PROJECT_REGISTRY"
fi

shorten() {
  local value="$1"
  local max="$2"

  if [ "${#value}" -le "$max" ]; then
    printf "%s" "$value"
  else
    printf "%s…" "${value:0:$((max - 1))}"
  fi
}

print_repo() {
  local repo="$1"
  local name branch status verify gate last_commit remote initialized short_name short_branch

  if ! git -C "$repo" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    return
  fi

  name="$(basename "$repo")"

  branch="$(git -C "$repo" branch --show-current 2>/dev/null || true)"
  if [ -z "$branch" ]; then
    branch="detached"
  fi

  if [ -n "$(git -C "$repo" status --short 2>/dev/null)" ]; then
    status="dirty"
  else
    status="clean"
  fi

  if [ -x "$repo/scripts/verify.sh" ]; then
    verify="yes"
  else
    verify="no"
  fi

  if [ -x "$repo/scripts/review-gate.sh" ]; then
    gate="yes"
  else
    gate="no"
  fi

  last_commit="$(git -C "$repo" log -1 --format='%h' 2>/dev/null || echo none)"

  if git -C "$repo" remote get-url origin >/dev/null 2>&1; then
    remote="yes"
  else
    remote="no"
  fi

  if [ "${REGISTERED_PATHS[$repo]+set}" = "set" ]; then
    initialized="yes"
  else
    initialized="no"
  fi

  short_name="$(shorten "$name" 22)"
  short_branch="$(shorten "$branch" 10)"

  printf "%-22s %-10s %-7s %-6s %-6s %-8s %-6s %-4s %s\n" \
    "$short_name" "$short_branch" "$status" "$verify" "$gate" "$last_commit" "$remote" "$initialized" "$repo"
}

printf "%-22s %-10s %-7s %-6s %-6s %-8s %-6s %-4s %s\n" \
  "PROJECT" "BRANCH" "STATUS" "VERIFY" "GATE" "COMMIT" "REMOTE" "INIT" "PATH"

printf "%-22s %-10s %-7s %-6s %-6s %-8s %-6s %-4s %s\n" \
  "-------" "------" "------" "------" "----" "------" "------" "----" "----"

while IFS= read -r gitdir; do
  repo="$(cd "$(dirname "$gitdir")" && pwd -P)"
  PRINTED_PATHS["$repo"]=1
  print_repo "$repo"
done < <(find "$WORKSPACE" -mindepth 1 -maxdepth 2 \( -type d -o -type f \) -name .git | sort)

if [ -f "$PROJECT_REGISTRY" ]; then
  while IFS=$'\t' read -r _registered_at path _name _branch _origin; do
    [ -n "$path" ] || continue
    if [ "${PRINTED_PATHS[$path]+set}" = "set" ]; then
      continue
    fi
    print_repo "$path"
  done < "$PROJECT_REGISTRY"
fi
