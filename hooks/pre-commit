#!/usr/bin/env bash
set -euo pipefail

# AI_AUTO worktree-safe hook — GLOBAL framework body. Reached through a project's
# thin pre-commit shim (which bakes AI_AUTO_HOME, unsets GIT_*, and execs us). The
# §4 self-heal guard below makes bare-name siblings resolve in ANY context.
: "${AI_AUTO_HOME:=$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)}"
# M1: prepend BOTH scripts/ and tools/ so bare-name tools/ helpers resolve in a minimal env.
case ":$PATH:" in *":$AI_AUTO_HOME/scripts:"*) ;; *) PATH="$AI_AUTO_HOME/scripts:$AI_AUTO_HOME/tools:$PATH";; esac

# git exports GIT_DIR / GIT_INDEX_FILE / GIT_WORK_TREE / GIT_PREFIX (and on some
# versions GIT_COMMON_DIR / GIT_NAMESPACE) into hook processes. The test suite below
# spawns git in throwaway repos; inheriting this repo's GIT_* would corrupt git state
# across every linked worktree, and an inherited git-exec-env var (GIT_EXTERNAL_DIFF /
# GIT_CONFIG_* / GIT_TRACE* / …) is arbitrary-command execution through a git call here.
# F1: the canonical denylist is single-sourced in hooks/git-scrub.sh (no four-copy drift).
# BLAST-H1 (fail-OPEN): a GLOBAL engine defect must NEVER brick every project's commit. If
# git-scrub.sh is missing/moved (an interrupted `git pull` in $AI_AUTO_HOME) or does not
# parse, sourcing it under `set -e` would rc=1 and BLOCK this commit. Guard it: source only
# when the file EXISTS and `bash -n` parses it; otherwise WARN LOUDLY and CONTINUE (the
# worst case is a commit without the git-env scrub — a smaller harm than blocking all work).
# shellcheck source=hooks/git-scrub.sh
if [ -f "$AI_AUTO_HOME/hooks/git-scrub.sh" ] && bash -n "$AI_AUTO_HOME/hooks/git-scrub.sh" 2>/dev/null; then
  . "$AI_AUTO_HOME/hooks/git-scrub.sh"
else
  printf '\033[33m[pre-commit] WARNING: AI_AUTO git-scrub.sh missing or unparseable (%s); continuing WITHOUT git-env scrub. NOT blocking commit.\033[0m\n' "$AI_AUTO_HOME/hooks/git-scrub.sh" >&2
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "${repo_root}"

echo "[pre-commit] running tests before commit..."
# pytest exit 5 == "no tests were collected"; a test-less repo (a freshly globalized
# project, a docs-only project) is not a FAILURE, so exit 5 must not block. Only a real
# failing run (exit 1-4) is fail-closed. Absence of a runner is a separate, positive
# discovery (warn + defer), never inferred from a nonzero exit.
pre_commit_run_pytest() {
  local rc
  if [ -x ".venv/bin/python" ]; then
    set +e; .venv/bin/python -m pytest -q; rc=$?; set -e
  elif command -v pytest >/dev/null 2>&1; then
    set +e; pytest -q; rc=$?; set -e
  else
    echo "[pre-commit] no pytest available (.venv missing and pytest not on PATH);" >&2
    echo "[pre-commit] cannot gate the test suite at commit. Not blocking the commit," >&2
    echo "[pre-commit] but run ai-auto gate + ai-auto verify before pushing." >&2
    return 0
  fi
  if [ "${rc}" -eq 5 ]; then
    echo "[pre-commit] pytest collected no tests (exit 5); nothing to gate, not blocking." >&2
    return 0
  fi
  return "${rc}"
}

# D2: engine self-host vs DERIVED project. Mirror the verify-scope engine detection
# (verify.sh:18 / review-gate.sh:507): this IS the engine only when AI_AUTO_HOME is the
# current repo. The ENGINE keeps its pytest / machinery gate. A DERIVED project must gate
# through its OWN verification seam (scripts/verify-project.sh via `ai-auto verify`,
# fail-closed when absent) — NOT a pytest-only run that no-ops a Node/Go/docker-smoke
# project even when it HAS real verification.
if [ "$AI_AUTO_HOME" -ef "$repo_root" ]; then
  # #3: pytest does not reach the bash machinery harness, so a regression in the
  # automation scripts/hooks slips past the commit gate. When this commit's STAGED
  # changes touch the framework AND a machinery harness is present, run the harness
  # instead: it runs pytest as its first step (superseding the plain run) and also
  # covers the bash machinery tests. Fail-closed via set -e.
  if [ -f scripts/verify-machinery.sh ] \
     && git diff --cached --name-only 2>/dev/null | grep -Eq '^(scripts/|hooks/)'; then
    echo "[pre-commit] framework files staged; running machinery verify (includes pytest)..."
    # OPCOST-HIGH-1: the gate's machinery-fold just ran this same ~6min self-test over an
    # IDENTICAL tested surface. Skip the re-run when a PASS marker for the exact surface-hash
    # exists (memoized in scripts/machinery-memo.sh); any surface change misses -> full run.
    # BLAST-H1 pattern: only source the (engine-internal) memo helper if it exists AND parses.
    if [ -f "$AI_AUTO_HOME/scripts/machinery-memo.sh" ] && bash -n "$AI_AUTO_HOME/scripts/machinery-memo.sh" 2>/dev/null; then
      # shellcheck source=scripts/machinery-memo.sh
      . "$AI_AUTO_HOME/scripts/machinery-memo.sh"
    fi
    if command -v machinery_memo_should_skip >/dev/null 2>&1 && machinery_memo_should_skip; then
      machinery_memo_skip_notice
    else
      verify-machinery.sh
      if command -v machinery_memo_record_pass >/dev/null 2>&1; then
        machinery_memo_record_pass
      fi
    fi
  else
    pre_commit_run_pytest
  fi
else
  # DERIVED project: gate via the project's own verification (scripts/verify-project.sh).
  # H1 (onboarding): `ai-auto setup` tells the user to make the de-pollution/adoption commit
  # immediately, but a freshly-adopted project has NO scripts/verify-project.sh yet — fail-closing
  # the HOOK here would BLOCK that very first documented commit. So when the file is absent the
  # hook LOUDLY WARNS (disclosed — NOT a silent no-op, which was D2's bug) and ALLOWS the commit;
  # when present it runs it and gates (fail-closed via set -e). The explicit `ai-auto verify` query
  # KEEPS its fail-closed exit 1 on absence (verify.sh product scope, unchanged) — a deliberate
  # query, not a commit gate.
  if [ -e ./scripts/verify-project.sh ]; then
    [ -x ./scripts/verify-project.sh ] \
      || echo "[pre-commit] scripts/verify-project.sh present but NOT executable — gating via bash." >&2
    echo "[pre-commit] running project verification (ai-auto verify, product scope)..."
    AI_AUTO_VERIFY_SCOPE=product "$AI_AUTO_HOME/scripts/verify.sh"
  else
    echo "[pre-commit] no project verification defined: scripts/verify-project.sh absent —" >&2
    echo "[pre-commit] commit NOT gated; add scripts/verify-project.sh to enable commit-time verification." >&2
  fi
fi
